# SMTP settings for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFY_EMAIL=your-email@gmail.com

# Postgres for FastAPI job platform (Phase 1+)
DATABASE_URL=postgresql://localhost/job_monitor

# Redis for Celery workers (Phase 4+)
REDIS_URL=redis://localhost:6379/0

# Optional alert channels (Phase 5+)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API auth (Phase 5+) — set true for multi-user deployments
API_AUTH_ENABLED=false
BOOTSTRAP_SECRET=

# Required for resume tailoring and match scoring
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Auto-apply login (Workday account creation/sign-in and some ATS portals)
APPLY_EMAIL=your-email@gmail.com
APPLY_PASSWORD=your-apply-portal-password
