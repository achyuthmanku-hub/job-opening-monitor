# SMTP settings for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFY_EMAIL=your-email@gmail.com

# Required for resume tailoring and match scoring
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Job platform API database (Postgres recommended; SQLite default for local dev)
# DATABASE_URL=postgresql://localhost/job_monitor
# DATABASE_URL=sqlite:///data/job_platform.db

# Auto-apply login (Workday account creation/sign-in and some ATS portals)
APPLY_EMAIL=your-email@gmail.com
APPLY_PASSWORD=your-apply-portal-password
